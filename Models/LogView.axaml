<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ParamVR.ViewModels"
        Width="1000"
        Height="500"
        Title="ParamVR.Chat Client Log Viewer"
        Icon="/Assets/ParamVR.Chat-Client.ico"
        WindowStartupLocation="CenterScreen"
        x:Class="ParamVR.Views.LogView"
        x:DataType="vm:LogViewViewModel">


    <ScrollViewer x:Name="ScrollViewer">
        <SelectableTextBlock x:Name="LogTextBlock" FontFamily="Consolas, Noto Sans Mono, JetBrains Mono, DejaVu Sans Mono, monospace"/>
    </ScrollViewer>
</Window>