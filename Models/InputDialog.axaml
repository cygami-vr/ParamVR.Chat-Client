<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ParamVR.ViewModels"
        Width="300"
        Height="135"
        CanResize="False"
        Title="{Binding Title}"
        WindowStartupLocation="CenterScreen"
        x:Class="ParamVR.Views.InputDialog"
        x:DataType="vm:InputDialogViewModel">

  <StackPanel Margin="12" Spacing="8">

    <TextBlock TextWrapping="Wrap" Text="{Binding Label}" />
    <!-- <TextBlock TextWrapping="Wrap" Text="Please enter the listen key obtained from the ParamVR.Chat website:" /> -->
    <TextBox Name="InputBox" />

    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6">
      <Button Content="OK" Click="OnOk"/>
      <Button Content="Cancel" Click="OnCancel"/>
    </StackPanel>
  </StackPanel>
</Window>