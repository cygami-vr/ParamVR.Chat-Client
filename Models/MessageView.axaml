<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ParamVR.ViewModels"
        Width="300"
        Height="95"
        CanResize="False"
        Title="{Binding Title}"
        Icon="/Assets/ParamVR.Chat-Client.ico"
        WindowStartupLocation="CenterScreen"
        x:Class="ParamVR.Views.MessageView"
        x:DataType="vm:MessageViewViewModel">

  <StackPanel Margin="12" Spacing="8">

    <TextBlock TextWrapping="Wrap" Text="{Binding Message}" />
    <!-- <TextBlock TextWrapping="Wrap" Text="Your ParamVR.Chat Client is out of date. Please update and try again." /> -->

    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6">
      <Button Content="OK" Click="OnOk"/>
    </StackPanel>
  </StackPanel>
</Window>